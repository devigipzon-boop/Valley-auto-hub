:root{
  --bg:#0b0b0b;
  --card:#141414;
  --accent:#ffd700;
  --primary:#8B0000;
  --muted:#cfcfcf;
  --container:1100px;
  --gap:18px;
  color-scheme: dark;
}
*{box-sizing:border-box}
body{
  margin:0; font-family:system-ui,-apple-system,Segoe UI,Roboto,"Helvetica Neue",Arial;
  background:var(--bg); color:#fff; line-height:1.45;
}
.container{max-width:var(--container);margin:0 auto;padding:28px;}
.header-inner{display:flex;align-items:center;justify-content:space-between;gap:12px}
.site-header{background:linear-gradient(90deg,var(--primary), #222); padding:12px 0; border-bottom:4px solid var(--accent)}
.logo{display:block}
.site-header nav a{color:#fff;margin-left:14px;text-decoration:none;font-weight:600;font-size:0.95rem}
.hero{padding:44px 0;text-align:center;background:linear-gradient(180deg, rgba(255,215,0,0.03), transparent)}
.hero h1{color:var(--accent);font-size:2rem;margin:0 0 10px}
.lead{color:var(--muted)}
.btn{display:inline-block;background:var(--primary);color:#fff;padding:10px 16px;border-radius:8px;text-decoration:none;font-weight:700;margin:6px;border:none}
.btn-whatsapp{background:#25D366;color:#063a2b}
.featured h2, .sell h2 {color:var(--accent)}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;margin-top:18px}
.card{background:var(--card);border-radius:10px;overflow:hidden;border:1px solid rgba(255,215,0,0.08)}
.card img{width:100%;height:150px;object-fit:cover;display:block}
.card-body{padding:12px}
.card-body h3{margin:0 0 6px;color:var(--accent);font-size:1.05rem}
.muted{color:var(--muted);margin:0;font-size:0.95rem}
.sell form{display:grid;gap:8px;max-width:640px}
input, textarea{background:#111;border:1px solid #222;padding:10px;border-radius:6px;color:#fff}
.site-footer{background:#000;padding:18px;text-align:center;color:#aaa;border-top:1px solid rgba(255,255,255,0.03)}
@media (prefers-reduced-motion: no-preference){
  .btn{transition:transform .12s ease; }
  .btn:hover{transform:translateY(-2px)}
} 